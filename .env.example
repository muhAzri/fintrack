# Copy to .env and adjust. Local dev DB is provided by docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fintrack?schema=public"

# Base URL used to build password-reset links (§6.0).
APP_URL="http://localhost:3000"

# SMTP for transactional email — password-reset links (§7). Fill with real creds.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Fintrack <no-reply@example.com>"
